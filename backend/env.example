# Backend Environment Variables Template
# Copy this to .dev.vars for local development or set as secrets in Cloudflare

# Connection string for your PostgreSQL database (e.g., Neon)
DATABASE_URL=postgres://user:password@host/dbname?sslmode=require

# Base URL for the frontend (for CORS and Origin checks)
FRONTEND_URL=https://lojinha-do-ze.vercel.app

# Additional allowed origins for CORS (comma-separated)
# ALLOWED_ORIGINS=http://localhost:3000,https://development-branch.vercel.app
