{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ESNext", "dom", "dom.iterable"],
    "strict": true,
    "skipLibCheck": true,
    "rootDir": ".",
    "types": ["@cloudflare/workers-types", "node"],
    "allowJs": true,
    "checkJs": false,
    "noEmit": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "baseUrl": "."
  },
  "include": ["src/**/*", "tests/**/*", "scripts/**/*"]
}
