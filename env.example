# Project Environment Variables Template

# Backend (Cloudflare Workers)
# See backend/env.example for details

# Frontend (Next.js)
NEXT_PUBLIC_API_PROXY_BASE=http://localhost:8787/api
# In production, this should point to your Worker's URL:
# NEXT_PUBLIC_API_PROXY_BASE=https://lojinha-do-ze-backend.YOUR_SUBDOMAIN.workers.dev/api

# Configurações de funcionalidades especiais (opcional)
# Identificadores de e-mail para acesso administrativo ou recursos experimentais
# Use apenas em ambiente de desenvolvimento ou através de variáveis protegidas no backend
ADMIN_INITIAL_EMAIL=admin@exemplo.com
EASTER_EGG_IDENTIFIER=seu@email.com
