# ------------------------------------------------------------------------------
# LOJINHA DO ZÉ - MASTER ENVIRONMENT CONFIGURATION
# ------------------------------------------------------------------------------

# [BACKEND - Cloudflare Worker / Wrangler]
# Local: postgresql://user:pass@localhost:5432/neondb
# Prod: Obter do console Neon (Direct Connection)
DATABASE_URL=postgresql://neondb_owner:npg_...

# Segredo para assinatura de tokens JWT
JWT_SECRET=super-secret-auth-token-key

# Mercado Pago Access Token (Secret)
MERCADO_PAGO_ACCESS_TOKEN=APP_USR-...

# Admin Registration Password (Protege a rota de criação de admin)
ADMIN_REG_PASSWORD=change-me-locally

# [FRONTEND - Next.js / Vercel]
# URL do seu Backend (usada no servidor Next.js para o Proxy)
# Local: http://127.0.0.1:8787 | Prod: https://seu-backend.workers.dev
BACKEND_URL=http://127.0.0.1:8787

# URL base para chamadas da API no Browser
# Local: http://localhost:3000/api | Prod: /api
NEXT_PUBLIC_API_URL=/api

# Chave pública do Mercado Pago
NEXT_PUBLIC_MERCADO_PAGO_PUBLIC_KEY=APP_USR-...

# URL base do site (usada para SEO e sitemaps)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Telefone de contato (WhatsApp) formatado com DDI: ex: 5511999999999
NEXT_PUBLIC_ZE_PHONE=5511999999999
ZE_PHONE=5511999999999

# WhatsApp API Configuration
# Options: 'official' or 'evolution'
WHATSAPP_API_TYPE=evolution
# For Evolution API:
WHATSAPP_API_URL=https://api.sua-instancia.com
WHATSAPP_API_KEY=sua_api_key
WHATSAPP_INSTANCE_NAME=sua_instancia
# For Official WhatsApp API:
WHATSAPP_PHONE_ID=seu_phone_id
WHATSAPP_ACCESS_TOKEN=seu_access_token
